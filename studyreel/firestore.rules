rules_version = '2';

// StudyReel Firestore 보안 규칙
// 모든 앱 데이터는 users/{uid} 아래에 저장된다
// (topics 문서, youtube_videos·watch_history 서브컬렉션, meta/streak).
// 로그인한 사용자는 '자신의' 데이터에만 접근할 수 있고, 그 외 경로는 기본 거부.
service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자 문서 본체(예: topics)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 하위 모든 컬렉션/문서(youtube_videos, watch_history, meta, ...)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
